# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/college_event_management

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Admin bootstrap (used by npm run seed:admin)
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@college.edu
ADMIN_PASSWORD=ChangeMe123!

# Email (SMTP - e.g. Gmail, SendGrid, Mailtrap)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="College Events <no-reply@college.edu>"

# Frontend URL (used in email links / CORS)
CLIENT_URL=http://localhost:3000

# File upload limits
MAX_UPLOAD_MB=5

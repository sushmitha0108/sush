{
  "info": {
    "name": "College Event Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "registrationId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@college.edu\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\",\n  \"department\": \"CSE\",\n  \"year\": 2\n}"
            }
          }
        },
        {
          "name": "Student Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@college.edu\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/admin/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@college.edu\",\n  \"password\": \"ChangeMe123!\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List/Search/Filter Events",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events?search=hack&category=Hackathon&upcoming=true&page=1&limit=10"
          }
        },
        {
          "name": "Get Event",
          "request": { "method": "GET", "url": "{{baseUrl}}/events/{{eventId}}" }
        },
        {
          "name": "Create Event (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/events",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"AI Hackathon 2026\",\n  \"description\": \"24 hour build sprint\",\n  \"category\": \"Hackathon\",\n  \"department\": \"CSE\",\n  \"date\": \"2026-08-15\",\n  \"time\": \"09:00\",\n  \"venue\": \"Main Auditorium\",\n  \"registrationDeadline\": \"2026-08-10\",\n  \"maxParticipants\": 100,\n  \"organizer\": \"CSE Department\"\n}"
            }
          }
        },
        {
          "name": "Update Event (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/events/{{eventId}}",
            "body": { "mode": "raw", "raw": "{\n  \"venue\": \"New Venue Hall\"\n}" }
          }
        },
        {
          "name": "Delete Event (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/events/{{eventId}}"
          }
        },
        {
          "name": "View Participants (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/events/{{eventId}}/participants"
          }
        },
        {
          "name": "Export Participants CSV (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/events/{{eventId}}/participants/export"
          }
        }
      ]
    },
    {
      "name": "Registrations",
      "item": [
        {
          "name": "Register for Event (student)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/registrations/{{eventId}}"
          }
        },
        {
          "name": "Cancel Registration (student)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/registrations/{{registrationId}}"
          }
        },
        {
          "name": "Approve/Reject Registration (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/registrations/{{registrationId}}/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"approved\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Scan QR / Mark Attendance (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/attendance/scan",
            "body": { "mode": "raw", "raw": "{\n  \"qrCode\": \"<token from QR image>\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Certificates",
      "item": [
        {
          "name": "Download Certificate",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/certificates/{{registrationId}}"
          }
        }
      ]
    },
    {
      "name": "Feedback",
      "item": [
        {
          "name": "Submit Feedback (student)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/feedback/{{eventId}}",
            "body": { "mode": "raw", "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Great event!\"\n}" }
          }
        },
        {
          "name": "Get Event Feedback (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/feedback/event/{{eventId}}"
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Dashboard (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/analytics/dashboard"
          }
        }
      ]
    },
    {
      "name": "Recommendations",
      "item": [
        {
          "name": "Get Recommendations (student)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/recommendations"
          }
        }
      ]
    }
  ]
}
